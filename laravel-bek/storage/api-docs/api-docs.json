    "components": {
        "schemas": {
            "CreatorResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "user": {
                        "$ref": "#/components/schemas/UserResource"
                    },
                    "naziv_stranice": {
                        "type": "string",
                        "example": "Petrov kanal"
                    },
                    "opis": {
                        "type": "string",
                        "example": "Opis mog kanala",
                        "nullable": true
                    },
                    "sub_levels": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/TierResource"
                        }
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "PostResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 10
                    },
                    "naslov": {
                        "type": "string",
                        "example": "Nova objava"
                    },
                    "sadrzaj": {
                        "type": "string",
                        "example": "Sadržaj objave..."
                    },
                    "datum_objave": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "pristup": {
                        "type": "string",
                        "example": "javno",
                        "enum": [
                            "javno",
                            "pretplatnici",
                            "nivo"
                        ]
                    },
                    "nivo_pristupa_id": {
                        "type": "integer",
                        "example": null,
                        "nullable": true
                    },
                    "creator": {
                        "properties": {
                            "id": {
                                "type": "integer",
                                "example": 3
                            },
                            "naziv_stranice": {
                                "type": "string",
                                "example": "Petrov kanal"
                            },
                            "user": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Petar Petrović"
                                    }
                                },
                                "type": "object"
                            }
                        },
                        "type": "object"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "SubscriptionResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 5
                    },
                    "creator": {
                        "properties": {
                            "id": {
                                "type": "integer",
                                "example": 2
                            },
                            "naziv_stranice": {
                                "type": "string",
                                "example": "Muzički kanal"
                            },
                            "user": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Marko Marković"
                                    }
                                },
                                "type": "object"
                            }
                        },
                        "type": "object"
                    },
                    "tier": {
                        "properties": {
                            "id": {
                                "type": "integer",
                                "example": 3
                            },
                            "naziv": {
                                "type": "string",
                                "example": "Gold"
                            },
                            "cena_mesecno": {
                                "type": "number",
                                "format": "float",
                                "example": 9.99
                            }
                        },
                        "type": "object",
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "example": "aktivna",
                        "enum": [
                            "aktivna",
                            "otkazana",
                            "istekla"
                        ]
                    },
                    "datum_pocetka": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "TierResource": {
                "properties": {
                    "id": {
                        "type": "integer",
